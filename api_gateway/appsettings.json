{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Proxy": {
    "Routes": {
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "content-projects-route": {
        "ClusterId": "content-cluster",
        "Match": { "Path": "/api/projects/{**catch-all}" }
      },
      "content-skills-route": {
        "ClusterId": "content-cluster",
        "Match": { "Path": "/api/skills/{**catch-all}" }
      },
      "content-experiences-route": {
        "ClusterId": "content-cluster",
        "Match": { "Path": "/api/experiences/{**catch-all}" }
      },
      "workflow-route": {
        "ClusterId": "workflow-cluster",
        "Match": { "Path": "/api/workflows/{**catch-all}" }
      },
      "application-route": {
        "ClusterId": "application-cluster",
        "Match": { "Path": "/api/applications/{**catch-all}" }
      },
      "job-offer-route": {
        "ClusterId": "job-offer-cluster",
        "Match": { "Path": "/api/job-offers/{**catch-all}" }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "cv-route": {
        "ClusterId": "cv-cluster",
        "Match": { "Path": "/api/cv/{**catch-all}" }
      }
    },
    "Clusters": {
      "user-cluster": {
        "Destinations": {
          "user-service-1": { "Address": "http://cv-user-service:8082" }
        }
      },
      "content-cluster": {
        "Destinations": {
          "content-service-1": { "Address": "http://cv-user-content-service:8083" }
        }
      },
      "workflow-cluster": {
        "Destinations": {
          "workflow-service-1": { "Address": "http://cv-workflow-service:8084" }
        }
      },
      "application-cluster": {
        "Destinations": {
          "application-service-1": { "Address": "http://cv-application-service:8085" }
        }
      },
      "job-offer-cluster": {
        "Destinations": {
          "job-offer-service-1": { "Address": "http://cv-job-offer-service:8086" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service-1": { "Address": "http://cv-notification-service:8087" }
        }
      },
      "cv-cluster": {
        "Destinations": {
          "cv-service-1": { "Address": "http://cv-cv-service:8088" }
        }
      }
    }
  }
}
