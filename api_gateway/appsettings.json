{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Proxy": {
    "Routes": {
      "user-service": {
        "ClusterId": "user-cluster",
        "RouteId": "user-route",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "content-service": {
        "ClusterId": "content-cluster",
        "RouteId": "content-route",
        "Match": { "Path": "/api/{projects,skills,experiences}/{**catch-all}" }
      },
      "workflow-service": {
        "ClusterId": "workflow-cluster",
        "RouteId": "workflow-route",
        "Match": { "Path": "/api/workflows/{**catch-all}" }
      },
      "application-service": {
        "ClusterId": "application-cluster",
        "RouteId": "application-route",
        "Match": { "Path": "/api/applications/{**catch-all}" }
      },
      "auth-service": {
        "ClusterId": "auth-cluster",
        "RouteId": "auth-route",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      }
    },
    "Clusters": {
      "user-cluster": {
        "Destinations": {
          "user-service-1": { "Address": "http://user-service:8082" }
        }
      },
      "content-cluster": {
        "Destinations": {
          "content-service-1": { "Address": "http://user-content-service:8083" }
        }
      },
      "workflow-cluster": {
        "Destinations": {
          "workflow-service-1": { "Address": "http://workflow-service:8084" }
        }
      },
      "application-cluster": {
        "Destinations": {
          "application-service-1": { "Address": "http://application-service:8085" }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "auth-service-1": { "Address": "http://monolith-service:8081" }
        }
      }
    }
  }
}
