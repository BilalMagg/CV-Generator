{
  "id": "cv-realm",
  "realm": "cv-realm",
  "displayName": "CV Generator",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 3600,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "offlineSessionMaxLifespan": 5184000,
  "users": [
    {
      "id": "00000000-0000-0000-0000-000000000001",
      "username": "testuser",
      "email": "test@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "test1234",
          "temporary": false
        }
      ],
      "realmRoles": ["user"],
      "attributes": {
        "userId": ["00000000-0000-0000-0000-000000000001"]
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Regular user role",
        "composite": false,
        "clientRole": false,
        "containerId": "cv-realm"
      },
      {
        "name": "admin",
        "description": "Administrator role",
        "composite": false,
        "clientRole": false,
        "containerId": "cv-realm"
      }
    ]
  },
  "clients": [
    {
      "id": "cv-gateway",
      "clientId": "cv-gateway",
      "name": "API Gateway",
      "description": "Backend API Gateway client",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "change-me-in-production",
      "redirectUris": [
        "http://localhost:8080/api/auth/callback",
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "attributes": {
        "access.token.lifespan": "3600",
        "post.logout.redirect.uris": "http://localhost:8080/*"
      }
    },
    {
      "id": "cv-frontend",
      "clientId": "cv-frontend",
      "name": "Angular Frontend",
      "description": "Frontend SPA client",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "attributes": {
        "access.token.lifespan": "3600",
        "post.logout.redirect.uris": "http://localhost:4200/*",
        "pkce.code.challenge.method": "S256"
      }
    }
  ]
}
